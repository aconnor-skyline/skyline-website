---
/**
 * Site-wide layout. Header is fixed-overlay (sits on top of the hero image,
 * transparent over photos, picks up a subtle blur as you scroll). Footer
 * lives on a dark cityscape background to match the Wix-era aesthetic.
 */
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Skyline Ventures — Mobility Consulting",
  description = "Mobility consulting services tailored to meet your company's needs. Helping clients navigate the complex landscape of mobility solutions.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />

    <!-- Preconnect to Unsplash so the hero image starts loading before the
         CSS background-image rule fires. Knocks ~150ms off the largest
         contentful paint on cold loads. -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Skyline Ventures" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Skyline Ventures home">
        <svg
          class="brand-mark"
          viewBox="0 0 32 32"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <!-- Stylized city skyline silhouette -->
          <g fill="currentColor">
            <rect x="2"  y="18" width="3" height="14" />
            <rect x="6"  y="10" width="5" height="22" />
            <rect x="12" y="14" width="3" height="18" />
            <rect x="16" y="4"  width="6" height="28" />
            <rect x="23" y="12" width="3" height="20" />
            <rect x="27" y="16" width="3" height="16" />
          </g>
        </svg>
        <span class="brand-text">
          <span class="brand-primary">SKYLINE</span>
          <span class="brand-secondary">VENTURES</span>
        </span>
      </a>
      <nav>
        <a href="/#services">Mobility Consulting</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-dark: #0a0a0c;
        --fg-on-light: #0a0a0c;
        --fg-on-light-muted: #555560;
        --fg-on-dark: #ffffff;
        --fg-on-dark-muted: rgba(255, 255, 255, 0.78);
        --fg-on-dark-subtle: rgba(255, 255, 255, 0.55);
        --accent: #a78bfa;
        --border-light: #e7e7ea;
        --border-dark: rgba(255, 255, 255, 0.15);
        --max-width: 1200px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--fg-on-light);
        font-family:
          "Helvetica Neue", -apple-system, BlinkMacSystemFont,
          "Segoe UI", Inter, system-ui, sans-serif;
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1,
      h2,
      h3 {
        font-weight: 400;
        letter-spacing: -0.015em;
        line-height: 1.1;
        margin: 0 0 0.6em;
      }

      h1 {
        font-size: clamp(2.4rem, 6vw, 4.8rem);
      }
      h2 {
        font-size: clamp(2rem, 4.5vw, 3.4rem);
      }
      h3 {
        font-size: 1.4rem;
      }

      p {
        margin: 0 0 1em;
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: opacity 0.15s ease;
      }
      a:hover {
        opacity: 0.65;
      }

      img,
      svg {
        max-width: 100%;
        display: block;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 32px;
      }

      /* ─── Header (overlay-style, sits on top of hero photo) ─── */
      .site-header {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 28px 40px;
        color: var(--fg-on-dark);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand-mark {
        width: 38px;
        height: 38px;
        color: var(--fg-on-dark);
        flex-shrink: 0;
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        line-height: 1;
      }

      .brand-primary {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 0.18em;
        color: var(--fg-on-dark);
      }

      .brand-secondary {
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.4em;
        color: rgba(255, 255, 255, 0.7);
        margin-top: 4px;
      }

      .site-header nav {
        display: flex;
        gap: 32px;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: 0.02em;
        color: var(--fg-on-dark);
      }

      @media (max-width: 700px) {
        .site-header {
          padding: 18px 22px;
        }
        .site-header nav {
          gap: 16px;
          font-size: 12px;
        }
        .brand-primary {
          font-size: 15px;
        }
        .brand-secondary {
          font-size: 8px;
        }
      }
    </style>
  </body>
</html>
