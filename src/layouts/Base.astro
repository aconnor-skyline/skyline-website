---
/**
 * Site-wide layout. Wraps every page with the same header / footer / global
 * styles so individual pages only need to render their own content.
 *
 * Style philosophy: black background, off-white text, generous whitespace,
 * one accent color (a muted blue from the Wix original). System UI font
 * stack — fast loads, native feel, no webfont CLS.
 */
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Skyline Ventures — Mobility Consulting",
  description = "Mobility consulting services tailored to meet your company's needs. Helping clients navigate the complex landscape of mobility solutions.",
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0c0e" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Skyline Ventures" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Skyline Ventures home">
        <svg
          class="brand-mark"
          viewBox="0 0 32 24"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <!-- Simplified city skyline icon — 5 rectangles of varying heights -->
          <rect x="0" y="14" width="4" height="10" />
          <rect x="5" y="8" width="6" height="16" />
          <rect x="12" y="11" width="3" height="13" />
          <rect x="16" y="4" width="7" height="20" />
          <rect x="24" y="9" width="3" height="15" />
          <rect x="28" y="13" width="4" height="11" />
        </svg>
        <span class="brand-text">Skyline Ventures</span>
      </a>
      <nav>
        <a href="/#services" class:list={[currentPath === "/" && "active"]}>Services</a>
        <a href="/#about">About</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span>© 2026 Skyline Ventures LLC</span>
          <span class="dot">·</span>
          <span>Greater Boston, MA</span>
        </div>
        <nav class="footer-nav">
          <a href="/privacy">Privacy Policy</a>
          <a href="/sms-terms">SMS Terms</a>
          <a href="mailto:contact@theskylineventures.com">Contact</a>
        </nav>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #0c0c0e;
        --bg-elev: #15151a;
        --fg: #f5f5f6;
        --fg-muted: #a3a3a8;
        --fg-subtle: #6b6b72;
        --accent: #6080ff;
        --border: #25252b;
        --max-width: 1100px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui,
          "Helvetica Neue", Arial, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1,
      h2,
      h3 {
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin: 0 0 0.5em;
      }

      h1 {
        font-size: clamp(2.4rem, 5.5vw, 4.5rem);
      }
      h2 {
        font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      }
      h3 {
        font-size: 1.25rem;
      }

      p {
        margin: 0 0 1em;
        color: var(--fg-muted);
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: opacity 0.15s ease;
      }
      a:hover {
        opacity: 0.7;
      }

      img,
      svg {
        max-width: 100%;
        display: block;
      }

      section {
        padding: 80px 24px;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
      }

      /* Header */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(12, 12, 14, 0.85);
        backdrop-filter: saturate(160%) blur(12px);
        -webkit-backdrop-filter: saturate(160%) blur(12px);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 28px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        font-size: 17px;
        letter-spacing: -0.01em;
      }

      .brand-mark {
        width: 28px;
        height: auto;
        fill: var(--fg);
      }

      .brand-text {
        color: var(--fg);
      }

      .site-header nav {
        display: flex;
        gap: 28px;
        font-size: 14px;
        color: var(--fg-muted);
      }

      .site-header nav a:hover {
        color: var(--fg);
        opacity: 1;
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 32px 28px;
        font-size: 13px;
        color: var(--fg-muted);
      }

      .footer-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
      }

      .footer-brand .dot {
        margin: 0 8px;
        color: var(--fg-subtle);
      }

      .footer-nav {
        display: flex;
        gap: 24px;
      }

      .footer-nav a:hover {
        color: var(--fg);
        opacity: 1;
      }

      @media (max-width: 600px) {
        .site-header {
          padding: 12px 18px;
        }
        .site-header nav {
          gap: 18px;
          font-size: 13px;
        }
        section {
          padding: 60px 18px;
        }
      }
    </style>
  </body>
</html>
