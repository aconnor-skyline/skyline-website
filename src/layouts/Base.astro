---
/**
 * Site-wide layout. Header is fixed-overlay (sits on top of the hero image,
 * transparent over photos, picks up a subtle blur as you scroll). Footer
 * lives on a dark cityscape background to match the Wix-era aesthetic.
 */
export interface Props {
  title?: string;
  description?: string;
  /**
   * Set to true for pages with a white background (legal pages, etc.) so the
   * white-on-transparent logo gets inverted to dark via CSS — otherwise it
   * would be invisible against the white header.
   */
  lightHeader?: boolean;
}

const {
  title = "Skyline Ventures — Mobility Consulting",
  description = "Mobility consulting services tailored to meet your company's needs. Helping clients navigate the complex landscape of mobility solutions.",
  lightHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />

    <!-- Preconnect to Unsplash so the hero image starts loading before the
         CSS background-image rule fires. Knocks ~150ms off the largest
         contentful paint on cold loads. -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Skyline Ventures" />
  </head>
  <body class={lightHeader ? "light-page" : undefined}>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Skyline Ventures home">
        <!-- Official Skyline Ventures logo. Sourced from the Wix-era brand
             asset and post-processed to a transparent background so it
             overlays cleanly on hero photos. -->
        <img
          src="/images/skyline-logo.png"
          alt="Skyline Ventures"
          class="brand-logo"
          width="500"
          height="500"
        />
      </a>
      <nav>
        <a href="/#features">Life App</a>
        <a href="/consulting">Mobility Consulting</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-dark: #0a0a0c;
        --fg-on-light: #0a0a0c;
        --fg-on-light-muted: #555560;
        --fg-on-dark: #ffffff;
        --fg-on-dark-muted: rgba(255, 255, 255, 0.78);
        --fg-on-dark-subtle: rgba(255, 255, 255, 0.55);
        --accent: #a78bfa;
        --border-light: #e7e7ea;
        --border-dark: rgba(255, 255, 255, 0.15);
        --max-width: 1200px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--fg-on-light);
        font-family:
          "Helvetica Neue", -apple-system, BlinkMacSystemFont,
          "Segoe UI", Inter, system-ui, sans-serif;
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1,
      h2,
      h3 {
        font-weight: 400;
        letter-spacing: -0.015em;
        line-height: 1.1;
        margin: 0 0 0.6em;
      }

      h1 {
        font-size: clamp(2.4rem, 6vw, 4.8rem);
      }
      h2 {
        font-size: clamp(2rem, 4.5vw, 3.4rem);
      }
      h3 {
        font-size: 1.4rem;
      }

      p {
        margin: 0 0 1em;
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: opacity 0.15s ease;
      }
      a:hover {
        opacity: 0.65;
      }

      img,
      svg {
        max-width: 100%;
        display: block;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 32px;
      }

      /* ─── Header (overlay-style, sits on top of hero photo) ─── */
      .site-header {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 28px 40px;
        color: var(--fg-on-dark);
      }

      .brand {
        display: flex;
        align-items: center;
      }

      .brand-logo {
        /* The logo PNG is square (500x500) with skyline + SKYLINE / VENTURES
           text. Sized big to be the dominant focal point of the header. */
        height: 305px;
        width: auto;
        display: block;
        /* On light-background pages (privacy / sms-terms) the white logo
           would be invisible. Swap to a dark version via filter only when
           the body has the `.light-page` class (set per-page where needed). */
      }
      body.light-page .brand-logo {
        /* Invert white → black so the logo shows on white legal pages. */
        filter: invert(1);
      }

      .site-header nav {
        display: flex;
        gap: 32px;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: 0.02em;
        color: var(--fg-on-dark);
      }
      body.light-page .site-header nav {
        /* On light pages the white nav text would be invisible — flip to
           dark to match the inverted logo. */
        color: var(--fg-on-light);
      }

      @media (max-width: 700px) {
        .site-header {
          padding: 18px 22px;
        }
        .site-header nav {
          gap: 16px;
          font-size: 12px;
        }
        .brand-logo {
          height: 200px;
        }
      }
    </style>
  </body>
</html>
