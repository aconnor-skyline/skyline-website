---
/**
 * Site-wide layout. Header is fixed-overlay (sits on top of the hero image,
 * transparent over photos, picks up a subtle blur as you scroll). Footer
 * lives on a dark cityscape background to match the Wix-era aesthetic.
 */
export interface Props {
  title?: string;
  description?: string;
  /**
   * Set to true for pages with a white background (legal pages, etc.) so the
   * white-on-transparent logo gets inverted to dark via CSS — otherwise it
   * would be invisible against the white header.
   */
  lightHeader?: boolean;
}

const {
  title = "Life App — by Skyline Ventures",
  description = "Your health, habits, and AI assistant — all in one place. The Life App is built by Skyline Ventures for iPhone and Mac.",
  lightHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon shown in browser tabs, bookmarks, and Google search results.
         We use the Life App icon (white "L." + LIFE wordmark on black) since
         it reads best at the small sizes Google + browsers render at. -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph — what shows up when the URL is shared in Slack,
         iMessage, Twitter, LinkedIn, etc. The image is shown ~1200x630
         in most previews; the square logo crops to a centered square
         with branding visible on either side. -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Skyline Ventures" />
    <meta property="og:image" content="https://theskylineventures.com/icon.png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />

    <!-- Twitter / X card metadata (uses og: tags above for image) -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://theskylineventures.com/icon.png" />
  </head>
  <body class={lightHeader ? "light-page" : undefined}>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Skyline Ventures home">
        <!-- Brand mark composed in HTML so we can size SKYLINE and VENTURES
             independently. The skyline silhouette is the cropped icon-only
             portion of the original Wix-era logo; SKYLINE / VENTURES are
             rendered as text below it for full typographic control. -->
        <img
          src="/images/skyline-icon-only.png"
          alt=""
          class="brand-icon"
          width="303"
          height="99"
        />
        <span class="brand-skyline">SKYLINE</span>
        <span class="brand-ventures">VENTURES</span>
      </a>
      <!-- Hamburger dropdown nav. Same UX on desktop + mobile — one button,
           opens a panel with every site link. The `<details>` element gives
           us native open/close behavior + keyboard support without JS,
           plus we layer a tiny bit of JS at the bottom of the body to also
           close it on outside-click. -->
      <details class="nav-dropdown">
        <summary aria-label="Open navigation menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <span class="nav-label">Menu</span>
        </summary>
        <div class="nav-panel">
          <a href="/#features">Life App</a>
          {/* Mobility Consulting link hidden — restore when re-launching consulting:
              <a href="/consulting">Mobility Consulting</a> */}
          <a href="/#contact">Contact</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/sms-terms">SMS Terms</a>
        </div>
      </details>
    </header>

    <main>
      <slot />
    </main>

    <!-- Tiny script to close the nav dropdown on outside-click + on link
         tap. Inline + minimal — no framework, no async — runs in <1ms. -->
    <script>
      (function () {
        const dropdown = document.querySelector("details.nav-dropdown");
        if (!dropdown) return;
        // Close when clicking outside the dropdown
        document.addEventListener("click", (event) => {
          if (!dropdown.contains(event.target)) {
            dropdown.removeAttribute("open");
          }
        });
        // Close when a nav link is tapped (so the panel doesn't linger
        // after the page navigates / scrolls to anchor)
        dropdown.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", () => {
            dropdown.removeAttribute("open");
          });
        });
      })();
    </script>

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-dark: #0a0a0c;
        --fg-on-light: #0a0a0c;
        --fg-on-light-muted: #555560;
        --fg-on-dark: #ffffff;
        --fg-on-dark-muted: rgba(255, 255, 255, 0.78);
        --fg-on-dark-subtle: rgba(255, 255, 255, 0.55);
        /* Life App brand blue — matches the small blue square in the
           "L." mark of the app icon. Used for eyebrows, hover states,
           accent squares on feature cards. */
        --accent: #4068F0;
        --border-light: #e7e7ea;
        --border-dark: rgba(255, 255, 255, 0.15);
        --max-width: 1200px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--fg-on-light);
        font-family:
          "Helvetica Neue", -apple-system, BlinkMacSystemFont,
          "Segoe UI", Inter, system-ui, sans-serif;
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1,
      h2,
      h3 {
        font-weight: 400;
        letter-spacing: -0.015em;
        line-height: 1.1;
        margin: 0 0 0.6em;
      }

      h1 {
        font-size: clamp(2.4rem, 6vw, 4.8rem);
      }
      h2 {
        font-size: clamp(2rem, 4.5vw, 3.4rem);
      }
      h3 {
        font-size: 1.4rem;
      }

      p {
        margin: 0 0 1em;
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: opacity 0.15s ease;
      }
      a:hover {
        opacity: 0.65;
      }

      img,
      svg {
        max-width: 100%;
        display: block;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 32px;
      }

      /* ─── Header (overlay-style, sits on top of hero photo) ─── */
      .site-header {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 28px 40px;
        color: var(--fg-on-dark);
      }

      .brand {
        /* Stack: skyline icon on top, SKYLINE big, VENTURES below. */
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        line-height: 1;
      }
      .brand-icon {
        /* Just the skyline silhouette (cropped from original logo) */
        width: 220px;
        height: auto;
        display: block;
      }
      .brand-skyline {
        font-size: 56px;
        font-weight: 400;
        letter-spacing: 0.18em;
        color: var(--fg-on-dark);
        line-height: 1;
        /* Pull tight against the icon above */
        margin-top: 4px;
      }
      .brand-ventures {
        /* Bigger than the original tiny VENTURES — about 30% of SKYLINE's
           size now, vs. the ~15% it was in the original image. */
        font-size: 18px;
        font-weight: 500;
        letter-spacing: 0.4em;
        /* Visually align centered under SKYLINE */
        padding-left: 0.4em;
        color: var(--fg-on-dark);
        line-height: 1;
        opacity: 0.92;
      }
      body.light-page .brand-icon {
        /* Invert white → black so the icon shows on white legal pages. */
        filter: invert(1);
      }
      body.light-page .brand-skyline,
      body.light-page .brand-ventures {
        color: var(--fg-on-light);
      }

      /* ─── Dropdown nav ─── */
      .nav-dropdown {
        position: relative;
      }
      .nav-dropdown summary {
        list-style: none; /* hide native disclosure triangle */
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--fg-on-dark);
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 999px;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .nav-dropdown summary::-webkit-details-marker { display: none; }
      .nav-dropdown summary:hover {
        background: rgba(255, 255, 255, 0.14);
        border-color: rgba(255, 255, 255, 0.3);
      }
      .nav-dropdown summary svg {
        width: 18px;
        height: 18px;
      }

      /* Light-page header (privacy / sms-terms): swap to dark colors */
      body.light-page .nav-dropdown summary {
        color: var(--fg-on-light);
        background: rgba(0, 0, 0, 0.05);
        border-color: rgba(0, 0, 0, 0.12);
      }
      body.light-page .nav-dropdown summary:hover {
        background: rgba(0, 0, 0, 0.09);
      }

      /* Dropdown panel — anchored to the right under the button */
      .nav-panel {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        min-width: 220px;
        background: rgba(15, 15, 18, 0.96);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
        z-index: 100;
        /* Subtle in animation when opening */
        animation: navDropIn 0.15s ease;
      }
      @keyframes navDropIn {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .nav-panel a {
        display: block;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
        transition: background 0.12s ease, color 0.12s ease;
      }
      .nav-panel a:hover {
        background: rgba(255, 255, 255, 0.07);
        color: #ffffff;
        opacity: 1;
      }

      /* On light pages the dropdown panel itself stays dark — high
         contrast against any background. */

      @media (max-width: 700px) {
        .site-header {
          padding: 14px 22px;
        }
        /* Mobile header brand — slightly smaller than before so the Life
           logo below has more breathing room from the Skyline mark. */
        .brand-icon {
          width: 105px;
        }
        .brand-skyline {
          font-size: 26px;
        }
        .brand-ventures {
          font-size: 9px;
        }
        /* On mobile, hide the "Menu" word — keep just the icon */
        .nav-dropdown summary {
          padding: 10px 12px;
        }
        .nav-label {
          display: none;
        }
      }
    </style>
  </body>
</html>
