---
/**
 * SMS Terms & Conditions. Mirrors the Wix-era version verbatim — describes
 * the "Skyline Ventures Security Alerts" 2FA program (one-time codes for
 * login and sensitive account actions).
 */
import Base from "../layouts/Base.astro";
const lastUpdated = "April 19, 2026";
---

<Base title="SMS Terms — Skyline Ventures">
  <section class="legal">
    <div class="container">
      <a href="/" class="back-link">← Back to home</a>
      <h1>SMS Terms &amp; Conditions</h1>
      <p class="updated">Last updated: {lastUpdated}</p>

      <h2>Program name</h2>
      <p>Skyline Ventures Security Alerts</p>

      <h2>Program description</h2>
      <p>
        Users who enable two-step verification receive transactional
        one-time security codes for login verification and sensitive
        account actions.
      </p>

      <h2>Message frequency</h2>
      <p>
        Message frequency varies based on account activity and security
        events.
      </p>

      <h2>Message and data rates</h2>
      <p>Message and data rates may apply.</p>

      <h2>Support</h2>
      <p>
        Reply <strong>HELP</strong> for help, or contact
        <a href="mailto:support@theskylineventures.com">
          support@theskylineventures.com
        </a>.
      </p>

      <h2>Opt-out</h2>
      <p>
        Reply <strong>STOP</strong> to unsubscribe from SMS messages at
        any time.
      </p>

      <h2>Consent</h2>
      <p>
        Users opt in by enabling two-step verification and providing their
        mobile number in account settings.
      </p>
    </div>
  </section>
</Base>

<style>
  .legal {
    padding: 80px 0 120px;
    background: var(--bg);
    color: var(--fg-on-light);
    min-height: 70vh;
  }
  .back-link {
    display: inline-block;
    color: var(--fg-on-light-muted);
    font-size: 14px;
    margin-bottom: 28px;
  }
  .back-link:hover { color: var(--fg-on-light); opacity: 1; }
  .legal h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--fg-on-light);
    margin: 0 0 8px;
  }
  .updated {
    color: var(--fg-on-light-muted);
    font-size: 13px;
    margin: 0 0 2.5em;
  }
  .legal h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg-on-light);
    margin-top: 2em;
    margin-bottom: 0.6em;
  }
  .legal p {
    color: var(--fg-on-light-muted);
    font-size: 1rem;
    line-height: 1.7;
  }
  .legal a {
    color: var(--accent);
  }
  .legal a:hover { opacity: 0.7; }
</style>
