---
/**
 * Privacy Policy. Text mirrors the Wix-era version verbatim — narrowly
 * scoped to SMS-based account-security data collection, since that's the
 * only personal data Skyline Ventures actually handles.
 */
import Base from "../layouts/Base.astro";
const lastUpdated = "April 19, 2026";
---

<Base title="Privacy Policy — Skyline Ventures" lightHeader={true}>
  <section class="legal">
    <div class="container">
      <a href="/" class="back-link">← Back to home</a>
      <h1>Privacy Policy</h1>
      <p class="updated">Last updated: {lastUpdated}</p>

      <p>
        Skyline Ventures ("we," "our," "us") collects limited personal
        information required to provide account security text messages,
        including phone number, message delivery status, and related
        account security metadata.
      </p>

      <h2>How we use data</h2>
      <ul>
        <li>To send one-time security verification codes.</li>
        <li>To protect account access and sensitive actions.</li>
        <li>To maintain security logs and prevent fraud.</li>
      </ul>

      <h2>Data sharing</h2>
      <p>
        We do not sell personal information. We do not share personal
        information with third parties for marketing. We only share with
        service providers necessary to deliver messages (for example, SMS
        infrastructure providers).
      </p>

      <h2>User choices</h2>
      <p>
        You may disable SMS-based 2FA in account settings. You may opt out
        of SMS by replying <strong>STOP</strong>.
      </p>

      <h2>Contact</h2>
      <p>
        <a href="mailto:contact@theskylineventures.com">
          contact@theskylineventures.com
        </a>
      </p>
    </div>
  </section>
</Base>

<style>
  .legal {
    /* Top padding clears the absolute-positioned header so the back-link
       sits ~30px below the SKYLINE / VENTURES brand mark — close enough
       to feel intentional, far enough not to crowd it. */
    padding: 200px 0 120px;
    background: var(--bg);
    color: var(--fg-on-light);
    min-height: 70vh;
  }
  @media (max-width: 700px) {
    .legal {
      padding-top: 165px;
    }
  }
  .back-link {
    display: inline-block;
    color: var(--fg-on-light-muted);
    font-size: 14px;
    margin-bottom: 28px;
  }
  .back-link:hover { color: var(--fg-on-light); opacity: 1; }
  .legal h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--fg-on-light);
    margin: 0 0 8px;
  }
  .updated {
    color: var(--fg-on-light-muted);
    font-size: 13px;
    margin: 0 0 2.5em;
  }
  .legal h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg-on-light);
    margin-top: 2em;
    margin-bottom: 0.6em;
  }
  .legal p {
    color: var(--fg-on-light-muted);
    font-size: 1rem;
    line-height: 1.7;
  }
  .legal ul {
    color: var(--fg-on-light-muted);
    padding-left: 1.4em;
    line-height: 1.7;
  }
  .legal ul li { margin-bottom: 0.4em; }
  .legal a {
    color: var(--accent);
  }
  .legal a:hover { opacity: 0.7; }
</style>
