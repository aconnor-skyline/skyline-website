---
/**
 * Life App product page. Showcases Skyline Ventures' flagship consumer
 * product alongside the consulting business. Uses Option A (the modern
 * angular glass-building photo) as the hero background — more "tech /
 * product" feel than the consulting cityscape shots.
 *
 * Copy is intentionally generic-but-confident — fill in the specifics
 * (App Store link, screenshots, pricing, waitlist) when you're ready
 * to launch publicly.
 */
import Base from "../layouts/Base.astro";

const HERO_IMAGE = "/images/option-A-skyscrapers.jpg";
const FOOTER_IMAGE = "/images/footer.jpg";

const features = [
  {
    title: "Smart health tracking",
    body: "Auto-sync from WHOOP, Apple Health, and your scale. Recovery, strain, sleep, BMI, calories, workouts — all in one place.",
    icon: "health",
  },
  {
    title: "Jarvis: your AI partner",
    body: "Voice or text. Log meals by saying what you ate. Ask questions, plan workouts, set reminders. Bring your own LLM key — costs are yours.",
    icon: "voice",
  },
  {
    title: "Habits that stick",
    body: "Track streaks, complete daily check-ins, see weekly patterns. Built around science-backed behavior change, not gamification fluff.",
    icon: "habit",
  },
  {
    title: "Calendar + tasks unified",
    body: "Daily planner pulls from your calendar, project tasks, and habits into one schedule. Tap to mark done. Drag to reorder.",
    icon: "calendar",
  },
  {
    title: "Built for iPhone + Mac",
    body: "Native apps on both platforms, syncing in real-time via Supabase. Use voice on the go, then dig into the data on your laptop.",
    icon: "device",
  },
  {
    title: "Customize what you see",
    body: "Hide sections you don't use. Don't have a WHOOP? Turn it off. Don't track nutrition? Hide it. Your dashboard, your way.",
    icon: "tune",
  },
];
---

<Base
  title="Life App — by Skyline Ventures"
  description="Your health, habits, and AI assistant — all in one place. The Life App is built by Skyline Ventures for iPhone and Mac."
>
  {/* ─────────────── HERO ─────────────── */}
  <section
    class="app-hero"
    style={`background-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0.65) 100%), url('${HERO_IMAGE}')`}
  >
    <div class="app-hero-content">
      <span class="eyebrow">A Skyline Ventures product</span>
      <img
        src="/images/life-app-logo.png"
        alt="Life — by Skyline Ventures"
        class="life-logo"
        width="1024"
        height="1024"
      />
      <p class="app-hero-sub">
        Your health, habits, and AI assistant —<br />
        all in one place.
      </p>
      <div class="cta-row">
        <a href="#features" class="btn btn-primary">See what it does</a>
        <a href="mailto:contact@theskylineventures.com?subject=Life%20App%20early%20access" class="btn btn-ghost">
          Request early access →
        </a>
      </div>
      <p class="status-pill">In active development · Coming to App Store</p>
    </div>
  </section>

  {/* ─────────────── FEATURES (light) ─────────────── */}
  <section id="features" class="features">
    <div class="container">
      <div class="features-intro">
        <h2>Built around how you actually live.</h2>
        <p>
          Most life apps make you do the work of integrating your tools.
          Life App pulls from the platforms you already use — Apple Health,
          WHOOP, your calendar, your scale — and turns the noise into one
          calm dashboard you actually want to open.
        </p>
      </div>

      <div class="feature-grid">
        {features.map((f) => (
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">
              <span class="square outer"></span>
              <span class="square inner"></span>
            </div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────── PHILOSOPHY (dark accent block) ─────────────── */}
  <section class="philosophy">
    <div class="container philosophy-inner">
      <span class="eyebrow eyebrow-dark">Why we built it</span>
      <h2>
        We were tired of toggling between<br />five apps to plan one day.
      </h2>
      <p>
        Life App isn't trying to replace your specialist tools — it's the
        layer above them that turns scattered data into one clear daily
        picture. Recovery score, today's calorie net, what's on your
        calendar, which habits matter most this week. Built for people who
        take their performance seriously and don't want to spend an hour a
        day managing it.
      </p>
    </div>
  </section>

  {/* ─────────────── EARLY ACCESS CTA (light) ─────────────── */}
  <section class="early-access">
    <div class="container early-access-inner">
      <h2>Want early access?</h2>
      <p>
        We're building Life App in public, shipping fast, and inviting a
        small group of testers before the App Store launch. If you want in,
        send us a note and we'll add you to the list.
      </p>
      <a
        href="mailto:contact@theskylineventures.com?subject=Life%20App%20early%20access"
        class="btn btn-primary btn-large"
      >
        Email us about early access →
      </a>
    </div>
  </section>

  {/* ─────────────── CONTACT / FOOTER (full-bleed photo) ─────────────── */}
  <section
    id="contact"
    class="contact-footer"
    style={`background-image: linear-gradient(180deg, rgba(10,10,12,0.7) 0%, rgba(10,10,12,0.85) 100%), url('${FOOTER_IMAGE}')`}
  >
    <div class="container contact-grid">
      <div class="contact-brand">
        <h2>Skyline Ventures</h2>
      </div>
      <div class="contact-info">
        <div class="contact-block">
          <h3>Contact Info</h3>
          <a href="mailto:contact@theskylineventures.com">
            contact@theskylineventures.com
          </a>
        </div>
        <div class="contact-block">
          <h3>Address</h3>
          <p>Greater Boston, MA</p>
        </div>
      </div>
    </div>
    <div class="contact-bottom container">
      <span>© 2026 Skyline Ventures LLC</span>
      <nav>
        <a href="/privacy">Privacy Policy</a>
        <a href="/sms-terms">SMS Terms</a>
      </nav>
    </div>
  </section>
</Base>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    min-height: 90vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--fg-on-dark);
    display: flex;
    align-items: center;
    padding: 0 48px;
  }
  .app-hero-content {
    max-width: 720px;
  }
  .eyebrow {
    display: block;
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* Generous bottom margin so the logo below has clear breathing room
       and doesn't visually crowd the eyebrow text. */
    margin: 0 0 36px;
  }
  .life-logo {
    /* Logo trimmed to 515x508 — sized small enough to feel like a brand
       mark, not a billboard. Eyebrow above it stays readable. */
    width: clamp(110px, 14vw, 170px);
    height: auto;
    display: block;
    margin: 0 0 32px;
  }
  .app-hero h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 24px;
    color: var(--fg-on-dark);
  }
  .app-hero-sub {
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    color: var(--fg-on-dark-muted);
    line-height: 1.45;
    margin: 0 0 36px;
  }
  .cta-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .btn {
    display: inline-block;
    padding: 14px 26px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 15px;
    transition: all 0.15s ease;
  }
  .btn-large {
    padding: 18px 32px;
    font-size: 16px;
  }
  .btn-primary {
    background: var(--fg-on-dark);
    color: var(--bg-dark);
  }
  .btn-primary:hover { transform: translateY(-1px); opacity: 1; }
  .btn-ghost {
    color: var(--fg-on-dark);
    border: 1px solid rgba(255,255,255,0.4);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); opacity: 1; }
  .status-pill {
    display: inline-block;
    background: rgba(255,255,255,0.08);
    color: var(--fg-on-dark-muted);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 12px;
    margin: 0;
  }

  /* ─── FEATURES ─── */
  .features {
    background: var(--bg);
    padding: 140px 0;
  }
  .features-intro {
    max-width: 720px;
    margin-bottom: 80px;
  }
  .features-intro h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--fg-on-light);
    margin: 0 0 20px;
  }
  .features-intro p {
    font-size: 1.05rem;
    color: var(--fg-on-light-muted);
    line-height: 1.6;
    margin: 0;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px 48px;
  }
  .feature-card { /* Just spacing, no card chrome */ }
  .feature-icon {
    position: relative;
    width: 36px;
    height: 36px;
    margin-bottom: 22px;
  }
  .feature-icon .square {
    position: absolute;
    width: 22px;
    height: 22px;
    display: block;
  }
  .feature-icon .outer {
    top: 0;
    left: 0;
    border: 1.5px solid var(--fg-on-light);
    background: transparent;
  }
  .feature-icon .inner {
    bottom: 0;
    right: 0;
    background: var(--accent);
  }
  .feature-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
    color: var(--fg-on-light);
  }
  .feature-card p {
    color: var(--fg-on-light-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 920px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px 32px;
    }
  }
  @media (max-width: 640px) {
    .feature-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  /* ─── PHILOSOPHY (dark) ─── */
  .philosophy {
    background: var(--bg-dark);
    color: var(--fg-on-dark);
    padding: 120px 0;
  }
  .philosophy-inner {
    max-width: 760px;
  }
  .eyebrow-dark {
    color: var(--accent);
  }
  .philosophy h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 400;
    color: var(--fg-on-dark);
    margin: 0 0 24px;
    line-height: 1.2;
  }
  .philosophy p {
    color: var(--fg-on-dark-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
  }

  /* ─── EARLY ACCESS ─── */
  .early-access {
    background: var(--bg);
    padding: 140px 0;
    text-align: center;
  }
  .early-access-inner {
    max-width: 580px;
  }
  .early-access h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--fg-on-light);
    margin: 0 0 18px;
  }
  .early-access p {
    color: var(--fg-on-light-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0 0 36px;
  }

  /* ─── CONTACT / FOOTER ─── */
  .contact-footer {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--fg-on-dark);
    padding: 100px 0 32px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
    margin-bottom: 80px;
  }
  .contact-brand h2 {
    font-size: clamp(1.6rem, 2.6vw, 2rem);
    font-weight: 700;
    margin: 0;
    color: var(--fg-on-dark);
    letter-spacing: -0.01em;
  }
  .contact-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .contact-block h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--fg-on-dark);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .contact-block a,
  .contact-block p {
    color: var(--fg-on-dark-muted);
    font-size: 14px;
    margin: 0;
    line-height: 1.5;
  }
  .contact-block a:hover {
    color: var(--fg-on-dark);
    opacity: 1;
  }
  .contact-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 24px;
    border-top: 1px solid var(--border-dark);
    font-size: 12px;
    color: var(--fg-on-dark-subtle);
    flex-wrap: wrap;
    gap: 16px;
  }
  .contact-bottom nav {
    display: flex;
    gap: 28px;
  }
  .contact-bottom a:hover {
    color: var(--fg-on-dark);
    opacity: 1;
  }

  @media (max-width: 920px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .contact-info {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
